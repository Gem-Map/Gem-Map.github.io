---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-40 w-full border-b border-slate-200 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-900/80">
	<nav class="mx-auto flex max-w-7xl items-center justify-between p-4 lg:px-8" aria-label="Global">
		<div class="flex lg:flex-1">
			<a href="/" class="-m-1.5 p-1.5 text-xl font-bold tracking-tight">
				<span class="gem-gradient-text">{SITE_TITLE}</span>
			</a>
		</div>
		<div class="flex gap-x-8">
			<HeaderLink href="/" class="text-sm font-semibold leading-6 text-slate-900 hover:text-indigo-primary dark:text-slate-100 dark:hover:text-teal-accent">Home</HeaderLink>
			<HeaderLink href="/blog" class="text-sm font-semibold leading-6 text-slate-900 hover:text-indigo-primary dark:text-slate-100 dark:hover:text-teal-accent">Blog</HeaderLink>
			<HeaderLink href="/about" class="text-sm font-semibold leading-6 text-slate-900 hover:text-indigo-primary dark:text-slate-100 dark:hover:text-teal-accent">About</HeaderLink>
		</div>
		<div class="flex lg:flex-1 lg:justify-end gap-4 items-center">
			<a href="https://github.com/Gem-Map" target="_blank" class="text-slate-500 hover:text-indigo-primary dark:text-slate-400 dark:hover:text-teal-accent">
				<span class="sr-only">GitHub</span>
				<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
				</svg>
			</a>
			<ThemeToggle />
		</div>
	</nav>
</header>
