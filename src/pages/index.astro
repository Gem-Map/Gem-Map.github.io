---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white dark:bg-gray-0 transition-colors duration-300">
		<Header />
		<main class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
			<section class="text-center mb-24 max-w-3xl mx-auto">
				<div class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold tracking-wide uppercase bg-primary-20/30 text-primary-100 rounded-full dark:bg-secondary-40/10 dark:text-secondary-40">
					Hidden Photo Spot Finder
				</div>
				<h1 class="text-5xl font-extrabold tracking-tight text-gray-0 sm:text-7xl dark:text-white mb-8">
					<span class="gem-gradient-text">{SITE_TITLE}</span>
				</h1>
				<p class="text-xl leading-relaxed text-gray-50 dark:text-gray-90">
					{SITE_DESCRIPTION}
				</p>
				<div class="mt-10 flex flex-wrap items-center justify-center gap-6">
					<a href="#posts" class="gem-btn-primary">기록 보러가기</a>
					<a href="/about" class="text-sm font-bold leading-6 text-gray-0 dark:text-white hover:text-primary-40 transition-colors">팀 소개 →</a>
				</div>
			</section>

			<section id="posts">
				<div class="flex items-end justify-between mb-12 border-b border-gray-90/50 pb-6 dark:border-gray-10/50">
					<div>
						<h2 class="text-3xl font-bold text-gray-0 dark:text-white mb-2 text-left">Gem있는 Writing</h2>
						<p class="text-gray-50 dark:text-gray-90">Gemmap 팀의 여정과 인사이트</p>
					</div>
					<a href="/blog" class="text-sm font-bold text-primary-40 dark:text-secondary-40 hover:underline">전체보기</a>
				</div>
				
				<ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 list-none p-0">
					{
						posts.map((post) => (
							<li class="p-0">
								<a href={`/blog/${post.id}/`} class="block group no-underline h-full">
									<article class="gem-card h-full flex flex-col hover:-translate-y-2">
										<div class="aspect-[16/10] w-full overflow-hidden rounded-xl mb-6 bg-white dark:bg-gray-10 border border-gray-90/20">
											{post.data.heroImage && (
												<Image 
													src={post.data.heroImage} 
													alt="" 
													width={720}
													height={450}
													class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
												/>
											)}
										</div>
										<div class="flex-1 flex flex-col px-1">
											<div class="flex flex-wrap items-center gap-2 mb-4 text-left">
												{post.data.tags && post.data.tags.slice(0, 2).map(tag => (
													<span class="gem-tag">
														#{tag}
													</span>
												))}
												<FormattedDate date={post.data.pubDate} class="ml-auto text-xs font-medium text-gray-50 dark:text-gray-90" />
											</div>
											<h3 class="text-2xl font-bold text-gray-0 dark:text-white mb-3 group-hover:text-primary-40 dark:group-hover:text-secondary-40 transition-colors leading-tight text-left">
												{post.data.title}
											</h3>
											<p class="text-gray-50 dark:text-gray-90 line-clamp-2 text-sm leading-relaxed text-left">
												{post.data.description}
											</p>
										</div>
									</article>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
