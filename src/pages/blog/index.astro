---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white dark:bg-gray-0 transition-colors duration-300">
		<Header />
		<main class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
			<section class="mb-16 border-b border-gray-90/50 pb-8 dark:border-gray-10/50">
				<h1 class="text-4xl font-black tracking-tight text-gray-0 dark:text-white sm:text-5xl mb-4 text-left">
					Gem있는 Writing
				</h1>
				<p class="text-xl text-gray-50 dark:text-gray-90 text-left">
					Gemmap 팀의 여정과 인사이트가 담긴 보석 같은 기록들입니다.
				</p>
			</section>
			
			<ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 list-none p-0">
				{
					posts.map((post) => (
						<li class="p-0">
							<a href={`/blog/${post.id}/`} class="block group no-underline h-full">
								<article class="gem-card h-full flex flex-col hover:-translate-y-2">
									<div class="aspect-[16/10] w-full overflow-hidden rounded-xl mb-6 bg-white dark:bg-gray-10 border border-gray-90/20">
										<img 
											src={post.data.heroImage} 
											alt="" 
											class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
										/>
									</div>
									<div class="flex-1 flex flex-col px-1">
										<div class="flex flex-wrap items-center gap-2 mb-4 text-left">
											{post.data.tags && post.data.tags.map(tag => (
												<span class="gem-tag">
													#{tag}
												</span>
											))}
											<FormattedDate date={post.data.pubDate} class="ml-auto text-xs font-medium text-gray-50 dark:text-gray-90" />
										</div>
										<h3 class="text-2xl font-bold text-gray-0 dark:text-white mb-3 group-hover:text-primary-40 dark:group-hover:text-secondary-40 transition-colors leading-tight text-left">
											{post.data.title}
										</h3>
										<p class="text-gray-50 dark:text-gray-90 line-clamp-2 text-sm leading-relaxed text-left">
											{post.data.description}
										</p>
									</div>
								</article>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
