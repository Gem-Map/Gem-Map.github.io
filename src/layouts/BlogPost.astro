---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

// GA4 Measurement ID should be set in environment variables
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_ID;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		{GA_MEASUREMENT_ID && (
			<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
			<script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
				window.dataLayer = window.dataLayer || [];
				function gtag(){dataLayer.push(arguments);}
				gtag('js', new Date());
				gtag('config', GA_MEASUREMENT_ID);
			</script>
		)}
	</head>

	<body class="bg-slate-50 dark:bg-slate-950 transition-colors duration-300">
		<Header />
		<main class="mx-auto max-w-4xl px-6 py-12 lg:px-8">
			<article class="gem-card !p-0 overflow-hidden border-none shadow-none bg-transparent dark:bg-transparent">
				<div class="w-full aspect-[2/1] overflow-hidden rounded-2xl mb-8 shadow-xl">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" class="w-full h-full object-cover" />}
				</div>
				
				<div class="px-4 sm:px-0">
					<header class="text-center mb-12">
						<div class="flex items-center justify-center gap-x-4 text-sm text-slate-500 dark:text-slate-400 mb-4">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="italic">
										(최근 수정일: <FormattedDate date={updatedDate} />)
									</div>
								)
							}
						</div>
						<h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-5xl dark:text-white mb-6">
							{title}
						</h1>
						{tags && (
							<div class="flex flex-wrap justify-center gap-2">
								{tags.map(tag => (
									<span class="rounded-full bg-indigo-50 px-3 py-1 text-sm font-medium text-indigo-600 dark:bg-teal-900/30 dark:text-teal-400">
										#{tag}
									</span>
								))}
							</div>
						)}
					</header>

					<div class="prose prose-slate prose-indigo dark:prose-invert lg:prose-xl mx-auto
						prose-headings:font-bold prose-a:text-indigo-primary dark:prose-a:text-teal-accent
						prose-pre:rounded-xl prose-img:rounded-xl">
						<slot />
					</div>

					<footer class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800 text-center">
						<div class="flex flex-col items-center gap-4">
							<p class="text-sm text-slate-500 dark:text-slate-400">실시간 방문자 수</p>
							<img src={`https://hits.seeyoufarm.com/api/count/incr/badge.svg?url=${encodeURIComponent(Astro.url.href)}&count_bg=%236366F1&title_bg=%2314B8A6&icon=&icon_color=%23E7E7E7&title=hits&edge_flat=false`} alt="Hits" />
						</div>
					</footer>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
